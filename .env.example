# Email configuration for contact form
# Used in src/scripts/contact.js

# Option 1: Using Formspree (default)
# If you are using Formspree, you only need to set the RESEND_URL.
# The URL below is the default from the script. Replace it with your own Formspree endpoint URL.
RESEND_URL="https://formspree.io/f/xayzjvlg"

# Option 2: Using Resend API
# If you want to use the Resend API directly, you'll need to fill these out.
# This requires a backend or serverless function to securely handle the API key.
# Your frontend code should not expose the API key.
CONTACT_EMAIL="your-email@example.com"
CONTACT_SUBJECT="New Contact Form Submission | Searching for Lucet"
RESEND_API_KEY="your_resend_api_key_here"
